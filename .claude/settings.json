{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "go build ./... 2>&1 | grep -E '^.*\\.go:[0-9]+' | head -5",
            "timeout": 15000
          }
        ]
      }
    ]
  }
}
